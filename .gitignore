# ============================================================
# UMKM ERP Lite — .gitignore
# ============================================================

# ─── Sistem Operasi ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ─── Editor & IDE ─────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ─── Node (berjaga-jaga jika ditambahkan tooling) ─────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Log ──────────────────────────────────────────────────
*.log

# ─── Temporary ────────────────────────────────────────────
*.tmp
*.temp
*.bak

# ─── Build (jika nanti ada build step) ────────────────────
dist/
build/

# ─── Env (jika nanti ada konfigurasi env) ────────────────
.env
.env.local
.env.*.local